## Project Configuration
SITE_NAME="Denver Burners Volunteer Database"
SITE_DESCRIPTION="<p>Volunteer database for Denver Burners community events.</p>"
SITE_URL=http://volunteer.denverburners.org

## Docker Port Configuration
# Change these if you have port conflicts on the host machine
NGINX_PORT=80
DB_PORT=3306

## Docker User Configuration
# These MUST be set to match your host user for file permissions to work
# They are auto-populated during setup by running:
#   sed -i "s/^UID=.*/UID=$(id -u)/" .env && sed -i "s/^GID=.*/GID=$(id -g)/" .env
UID=REPLACE_ME
GID=REPLACE_ME

## Application Key
# Generate with: docker compose exec app php artisan key:generate
APP_KEY=SomeRandomString

## Database Configuration
DB_CONNECTION=mysql
DB_HOST=db
DB_DATABASE=volunteers
DB_USERNAME=volunteers
DB_PASSWORD=SomeSecretPassword

## Application Settings
APP_ENV=local
MAIL_DRIVER=log
BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

## Production SSL (only needed for HTTPS setup)
# List all domains for the SSL certificate, comma-separated
# The first domain is the primary and determines the cert directory path
#SSL_DOMAINS=example.com,www.example.com,other.example.com
